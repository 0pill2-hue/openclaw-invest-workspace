{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stage3_external_primary_v2",
  "title": "Stage3 External Primary Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "review_mode",
    "baseline",
    "package_audit",
    "review_batch",
    "items",
    "summary"
  ],
  "properties": {
    "contract_version": {
      "const": "stage3_external_primary_v2"
    },
    "review_mode": {
      "const": "batch_scoring_mode"
    },
    "baseline": {
      "$ref": "#/$defs/baseline"
    },
    "package_audit": {
      "$ref": "#/$defs/packageAudit"
    },
    "review_batch": {
      "$ref": "#/$defs/reviewBatch"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_name",
        "repo_url",
        "branch_name",
        "commit_hash",
        "commit_url",
        "package_id",
        "batch_id",
        "package_manifest_sha256",
        "package_prepared_at_utc",
        "package_preparer"
      ],
      "properties": {
        "repo_name": {
          "type": "string"
        },
        "repo_url": {
          "type": "string"
        },
        "branch_name": {
          "type": "string"
        },
        "commit_hash": {
          "type": "string"
        },
        "commit_url": {
          "type": "string"
        },
        "package_id": {
          "type": "string"
        },
        "batch_id": {
          "type": "string"
        },
        "package_manifest_sha256": {
          "type": "string"
        },
        "package_prepared_at_utc": {
          "type": [
            "string",
            "null"
          ]
        },
        "package_preparer": {
          "type": "string"
        }
      }
    },
    "packageAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_item_count",
        "received_item_count",
        "item_type_counts",
        "source_family_counts",
        "attachment_integrity"
      ],
      "properties": {
        "expected_item_count": {
          "type": "integer",
          "minimum": 1
        },
        "received_item_count": {
          "type": "integer",
          "minimum": 0
        },
        "item_type_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "source_family_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "attachment_integrity": {
          "type": "string",
          "enum": [
            "pass",
            "partial",
            "fail"
          ]
        }
      }
    },
    "reviewBatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_target",
        "review_mode",
        "package_prepared_at_utc",
        "prompt_submitted_at_utc",
        "response_completed_at_utc",
        "json_extracted_at_utc",
        "batch_wall_seconds_observed",
        "operator_active_seconds_observed",
        "attachment_bytes_total",
        "attachment_count",
        "reviewed_item_count",
        "normalized_item_wall_seconds",
        "timing_measurement_method"
      ],
      "properties": {
        "model_target": {
          "type": "string"
        },
        "review_mode": {
          "const": "batch_scoring_mode"
        },
        "package_prepared_at_utc": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt_submitted_at_utc": {
          "type": [
            "string",
            "null"
          ]
        },
        "response_completed_at_utc": {
          "type": [
            "string",
            "null"
          ]
        },
        "json_extracted_at_utc": {
          "type": [
            "string",
            "null"
          ]
        },
        "batch_wall_seconds_observed": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "operator_active_seconds_observed": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "attachment_bytes_total": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "attachment_count": {
          "type": "integer",
          "minimum": 0
        },
        "reviewed_item_count": {
          "type": "integer",
          "minimum": 0
        },
        "normalized_item_wall_seconds": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "timing_measurement_method": {
          "type": "string",
          "enum": [
            "observed_batch_plus_derived_per_item"
          ]
        }
      }
    },
    "focusEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_type",
        "entity_id",
        "label"
      ],
      "properties": {
        "entity_type": {
          "type": "string"
        },
        "entity_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "commonScores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_quality_score",
        "novelty_score",
        "materiality_score",
        "transmission_clarity_score",
        "source_reliability_score",
        "counterbalance_score",
        "timing_clarity_score"
      ],
      "properties": {
        "evidence_quality_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "novelty_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "materiality_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "transmission_clarity_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "source_reliability_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "counterbalance_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "timing_clarity_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "normalizedJudgement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stance",
        "time_horizon",
        "market_scope",
        "actionability",
        "duplicate_or_near_duplicate"
      ],
      "properties": {
        "stance": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "mixed",
            "neutral",
            "unclear"
          ]
        },
        "time_horizon": {
          "type": "string",
          "enum": [
            "short",
            "medium",
            "long",
            "mixed",
            "unknown"
          ]
        },
        "market_scope": {
          "type": "string",
          "enum": [
            "idiosyncratic",
            "industry",
            "sector",
            "macro",
            "cross_asset",
            "sentiment_only",
            "unknown"
          ]
        },
        "actionability": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unclear"
          ]
        },
        "duplicate_or_near_duplicate": {
          "type": "string",
          "enum": [
            "no",
            "possible",
            "yes"
          ]
        }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timing_source",
        "batch_wall_seconds_observed",
        "normalized_item_wall_seconds",
        "operator_active_seconds_share",
        "timing_comparability_note"
      ],
      "properties": {
        "timing_source": {
          "type": "string",
          "enum": [
            "derived_from_batch"
          ]
        },
        "batch_wall_seconds_observed": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "normalized_item_wall_seconds": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "operator_active_seconds_share": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "timing_comparability_note": {
          "type": "string"
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "document_or_item_id",
        "item_type",
        "source_family",
        "focus_entities",
        "status",
        "preservation_decision",
        "primary_claim",
        "evidence_summary",
        "evidence_refs",
        "risk_summary",
        "counterpoint_summary",
        "transmission_path",
        "common_scores",
        "normalized_judgement",
        "final_result_label",
        "analysis_confidence",
        "timing"
      ],
      "properties": {
        "item_id": {
          "type": "string"
        },
        "document_or_item_id": {
          "type": "string"
        },
        "item_type": {
          "type": "string",
          "enum": [
            "stock",
            "industry",
            "sector",
            "macro",
            "policy",
            "commodity",
            "rates_fx",
            "theme",
            "event",
            "multi_asset",
            "chatter",
            "opinion",
            "mixed",
            "unknown"
          ]
        },
        "source_family": {
          "type": "string"
        },
        "focus_entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/focusEntity"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "scored",
            "ambiguous",
            "insufficient_context",
            "skipped"
          ]
        },
        "preservation_decision": {
          "type": "string",
          "enum": [
            "preserve",
            "preserve_low_confidence",
            "merge_candidate",
            "needs_adjudication",
            "skipped"
          ]
        },
        "primary_claim": {
          "type": "string"
        },
        "evidence_summary": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_summary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "counterpoint_summary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transmission_path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "common_scores": {
          "$ref": "#/$defs/commonScores"
        },
        "normalized_judgement": {
          "$ref": "#/$defs/normalizedJudgement"
        },
        "final_result_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "analysis_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "timing": {
          "$ref": "#/$defs/timing"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scored_count",
        "ambiguous_count",
        "insufficient_context_count",
        "skipped_count",
        "item_type_counts",
        "source_family_counts",
        "status_counts",
        "preservation_counts",
        "timing_rollup",
        "normalization_readiness",
        "recommended_follow_up"
      ],
      "properties": {
        "scored_count": {
          "type": "integer",
          "minimum": 0
        },
        "ambiguous_count": {
          "type": "integer",
          "minimum": 0
        },
        "insufficient_context_count": {
          "type": "integer",
          "minimum": 0
        },
        "skipped_count": {
          "type": "integer",
          "minimum": 0
        },
        "item_type_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "source_family_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "status_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scored",
            "ambiguous",
            "insufficient_context",
            "skipped"
          ],
          "properties": {
            "scored": {
              "type": "integer",
              "minimum": 0
            },
            "ambiguous": {
              "type": "integer",
              "minimum": 0
            },
            "insufficient_context": {
              "type": "integer",
              "minimum": 0
            },
            "skipped": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "preservation_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "timing_rollup": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "batch_wall_seconds_observed",
            "normalized_item_wall_seconds",
            "operator_active_seconds_observed",
            "timing_measurement_method"
          ],
          "properties": {
            "batch_wall_seconds_observed": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            },
            "normalized_item_wall_seconds": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            },
            "operator_active_seconds_observed": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            },
            "timing_measurement_method": {
              "type": "string",
              "enum": [
                "observed_batch_plus_derived_per_item"
              ]
            }
          }
        },
        "normalization_readiness": {
          "type": "string",
          "enum": [
            "ready",
            "ready_with_gaps",
            "not_ready"
          ]
        },
        "recommended_follow_up": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
