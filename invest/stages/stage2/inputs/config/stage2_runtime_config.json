{
  "version": "2026-03-08-stage2-runtime-config-r1",
  "refine": {
    "text_validation": {
      "blog_min_effective_len": 80,
      "telegram_min_effective_len": 60,
      "premium_min_effective_len": 100,
      "selected_articles_min_text_len": 80,
      "short_meaningful_min_len": 45
    },
    "dedup": {
      "min_fingerprint_text_len": 80,
      "target_folders": [
        "market/news/selected_articles",
        "text/blog",
        "text/telegram",
        "text/premium/startale"
      ]
    },
    "filters": {
      "blog_ui_markers": [
        "본문 바로가기",
        "카테고리 이동",
        "검색",
        "my메뉴 열기",
        "메뉴 바로가기",
        "이 블로그"
      ],
      "premium_boilerplate_markers": [
        "disclaimer",
        "본 포스팅에 수록된 내용은",
        "매수/매도 추천",
        "투자 결과에 대한 법적 책임소재",
        "별도의 투자 상담",
        "구독자 여러분 스스로 공부"
      ],
      "attachment_cleanup": {
        "drop_line_patterns": [
          "(?i)^\\[/?MEDIA\\].*$",
          "(?i)^\\[ATTACH_KIND\\].*$",
          "(?i)^\\[ATTACH_TEXT_STATUS\\].*$",
          "(?i)^\\[ATTACH_[A-Z0-9_]+\\].*$"
        ],
        "drop_block_patterns": [
          "(?is)\\[ATTACH_TEXT\\]\\s*.*?\\s*\\[/ATTACH_TEXT\\]"
        ]
      },
      "tracking_query_prefixes": [
        "utm_",
        "fbclid",
        "gclid",
        "igshid",
        "mc_cid",
        "mc_eid",
        "spm",
        "ref",
        "ref_src"
      ],
      "allowed_link_domain_suffixes": [
        "naver.com",
        "telegra.ph",
        "t.me",
        "medium.com",
        "coindesk.com",
        "cointelegraph.com",
        "theblock.co",
        "bloomberg.com",
        "reuters.com",
        "cnbc.com",
        "marketwatch.com",
        "investing.com",
        "yahoo.com",
        "yna.co.kr",
        "yonhapnews.co.kr",
        "hankyung.com",
        "mk.co.kr",
        "sedaily.com",
        "edaily.co.kr",
        "fnnews.com",
        "newsis.com",
        "chosun.com",
        "joongang.co.kr",
        "donga.com",
        "khan.co.kr",
        "hani.co.kr"
      ],
      "blocked_link_domain_suffixes": [
        "telegram.org",
        "web.telegram.org",
        "facebook.com",
        "instagram.com",
        "x.com",
        "twitter.com"
      ]
    },
    "link_enrichment": {
      "target_folders": [
        "text/blog",
        "text/telegram",
        "text/premium/startale"
      ],
      "allow_all_domains_default": true,
      "fetch_timeout_sec": 6,
      "fetch_max_retries": 3,
      "fetch_backoff_base_sec": 0.7,
      "fetch_max_bytes": 350000,
      "fetch_max_text_chars": 3000,
      "max_urls_per_file": 12,
      "max_total_chars": 4000,
      "min_effective_add": 50
    }
  },
  "qc": {
    "universe": {
      "included_markets": [
        "KOSPI",
        "KOSDAQ",
        "KOSDAQ GLOBAL"
      ],
      "included_market_ids": [
        "STK",
        "KSQ"
      ]
    },
    "thresholds": {
      "min_valid_volume": 10,
      "max_daily_ret_abs": 0.35
    }
  }
}
