{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Invest Record Meta",
  "type": "object",
  "required": ["record_id", "source", "collected_at_utc", "status", "rule_version"],
  "properties": {
    "record_id": {"type": "string"},
    "source": {"type": "string", "enum": ["blog", "telegram", "ohlcv", "supply"]},
    "author": {"type": "string"},
    "published_at_utc": {"type": ["string", "null"]},
    "collected_at_utc": {"type": "string"},
    "content_hash": {"type": ["string", "null"]},
    "status": {"type": "string", "enum": ["raw", "clean", "quarantine"]},
    "rule_version": {"type": "string"},
    "reason": {"type": ["string", "null"]},
    "path": {"type": "string"}
  }
}
